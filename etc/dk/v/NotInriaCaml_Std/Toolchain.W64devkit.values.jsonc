// === ABIs ===
//
// - Darwin_arm64.Windows_x86_64 (the Wine dependency will work only with Rosetta 2 emulator)
//
// === STRATEGY ===
// Confer https://crosstool-ng.github.io/docs/toolchain-types/ for the terminology.
//
// TARGET is Windows x86_64 (cross-native compilation)
// 1. The "config" machine that runs the `./configure` script is Darwin or Linux using
//    the LLVM-MinGW x86_64 target cross-compiler toolchain with Darwin or Linux as the
//    toolchain execution ABI. The toolchain execution ABI does _not_ have to be x86_64.
// 2. The "build" machine that runs the `make` command which creates the native OCaml
//    compiler is a Wine x86_64 emulator, where the path has the w64devkit x86_64
//    target cross-compiler toolchain with _Windows_ as the toolchain execution ABI.
// 3. The "host" machine that runs the native OCaml compiler is a Wine x86_64 emulator.
// 4. The "target" machine that runs the OCaml compiled native code is presumably a real
//    Windows x86_64 machine.
//
// === EXAMPLES ===
//
// ./dk0 --trial -v -I etc/dk/v --trust-local-package CommonsBase_Win32 --trust-local-package NotMatveevKondratyev_Libinotify --trust-local-package CommonsBase_LLVM --trust-local-package CommonsBase_GNU --trust-local-package NotInriaCaml_Std --trust-local-package NotMitEdu_Kerberos get-object NotInriaCaml_Std.Toolchain.W64devkit@5.4.1 -s Release.Darwin_arm64.Windows_x86_64 -d target/ocaml-winx64
//
// === FOLDERS ===
//
// Note: The folders are local to the PID unless the `--install` mode is used.
// Install mode is untested as of dk0 2.4.2+rev-75.
//
// ${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1
//   The semi-permanent Wine prefix for whatever application is being installed.
//   You should not need to back it up (it is a full Windows installation) so it is a
//   state directory not a data directory.
//
// ${CACHE}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1/src
//   The OCaml source code with patches.
//   We use cache folders so we can get the absolute path and symlink it into
//   the Wine prefix.
//   Once the compilation is done, it is fine if the source code disappears. The only other
//   use for the source code is during Wine debugging.
{
    "$schema": "https://github.com/diskuv/dk/raw/refs/heads/V2_5/etc/jsonschema/dk-values.json",
    "schema_version": {
        "major": 1,
        "minor": 0
    },
    "forms": [
        {
            "id": "NotInriaCaml_Std.Toolchain.W64devkit@5.4.1",
            "precommands": {
                "sequential": true,
                "private": [
                    // --- ocaml-5.4.1.tar.gz ---
                    // convert the .tar.gz to .zip
                    "post-object CommonsBase_Std.Extract.F_TarToZip@0.1.0 -f ignored.zip modver=NotInriaCaml_Std.OCaml.Zip@5.4.1 tarfile=$(get-asset NotInriaCaml_Std.OCaml.Bundle@5.4.1 -p ocaml-5.4.1.tar.gz -f ocaml-5.4.1.tar.gz)",
                    // extract zip to 's' folder, stripping toplevel ocaml-5.4.1/ folder
                    "install-object NotInriaCaml_Std.OCaml.Zip@5.4.1 -s Release.Agnostic -m ./output.zip -n 1 -d s -e 'configure' -e 'runtime/*.sh' -e 'lambda/*.sh'",

                    // --- flexdll-0.44.zip ---
                    // extract to 's/flexdll' folder, stripping toplevel flexdll-0.44/ folder
                    "get-asset NotInriaCaml_Std.OCaml.Bundle@5.4.1 -p 0.44.zip -n 1 -d s/flexdll"
                ]
            },
            "function": {
                "envmods": [
                    // Compiling OCaml does not need a Wine GUI (this does not stop popups on macOS where Wine is linked to System libraries
                    // that can trigger dialogs)
                    "-DISPLAY"
                ],
                "commands": [
                    // DEV NOTE: we could stuff all of this into a shell script because OCaml requires a /bin/sh for ./configure.
                    // But that is a current OCaml shortcoming: at some point we could build OCaml from a dk0 build directly.
                    // In other words, resist the urge to stuff all of this into a non-Windows shell script.

                    // --- debugging in case of failure ---
                    [
                        "/bin/sh", "-c", "\"set | grep -E '^(PATH|DISPLAY)=' | sed 's/^/export /' > vars.source.sh\""
                    ],

                    // --- patch: ocaml-5.4.1-configure.patch ---
                    [
                        "/usr/bin/patch",
                        "--batch",
                        "--directory=s",
                        "-p1",
                        "-i", "$(--path=absnative get-asset NotInriaCaml_Std.Lookup@1.0.0 -p p -m ./ocaml-5.4.1-configure.patch -f ocaml-5.4.1-configure.patch)"
                    ],

                    // --- patch: use Compflags-win32.cmd not shell script Compflags
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "rm", "s/stdlib/Compflags"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "cp",
                        "$(get-asset NotInriaCaml_Std.Lookup@1.0.0 -p s -m ./Compflags-win32.cmd -f Compflags.cmd)",
                        "s/stdlib/Compflags.cmd"
                    ],

                    // --- clean move the patched OCaml source (s/) into cache ---
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "rm", "-rf", "${CACHE}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1/src"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mkdir", "-p", "${CACHE}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mv", "-n", "s", "${CACHE}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1/src"
                    ],

                    // --- create Wine prefix ---
                    // note: a wineserver is 1-1 with a Wine prefix. it may be started in the background if not already running.
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mkdir", "-p",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1"
                    ],
                    [
                        //      `enter-wine.sh --init WINEPREFIX`
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--init",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1"
                    ],
                    [
                        // Wait until the wineserver process has exited to avoid race conditions modifying the wine prefix in
                        // the background (wineserver) and in the foreground (the next steps of this W64devkit function).
                        "/bin/sh", "$(get-asset NotInriaCaml_Std.Lookup@1.0.0 -p s -m ./wait-wineserver.sh -f wait-wineserver.sh)"
                    ],

                    // --- C:\**: make parent directories
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mkdir", "-p",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/opt",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/src/NotInriaCaml_Std/w64devkit/5.4.1/bin"
                    ],

                    // --- C:\src\NotInriaCaml_Std\w64devkit\5.4.1\src: OCaml source code
                    // using a symlink
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "ln", "--symbolic", "--force",
                        "--target-directory", "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/src/NotInriaCaml_Std/w64devkit/5.4.1",
                        "${CACHEABS}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1/src"
                    ],

                    // --- C:\src\NotInriaCaml_Std\w64devkit\5.4.1\bin: Shims (cdsrc.sh, cdsrc.cmd)
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "cp",
                        "$(get-asset NotInriaCaml_Std.Lookup@1.0.0 -p s -m ./cdsrc-w64devkit.sh -f cdsrc.sh)",
                        "$(get-asset NotInriaCaml_Std.Lookup@1.0.0 -p s -m ./cdsrc-w64devkit.cmd -f cdsrc.cmd)",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/src/NotInriaCaml_Std/w64devkit/5.4.1/bin"
                    ],

                    // --- C:\opt\w64devkit: w64devkit toolchain with Windows x86_64 execution ABI ---
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "cp", "-r",
                        "$(get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.Windows_x86_64 -d :)",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/opt/w64devkit"
                    ],

                    // --- PATH: add C:\src\NotInriaCaml_Std\w64devkit\5.4.1\bin and w64devkit ---
                    [
                        //      `enter-wine.sh WINEPREFIX REG ADD HKEY_CURRENT_USER\Environment ...`
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1",
                        //      add to HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Environment which is:
                        //          %SystemRoot%\system32;%SystemRoot%;%SystemRoot%\system32\wbem;%SystemRoot%\system32\WindowsPowershell\v1.0
                        "REG", "ADD", "HKEY_CURRENT_USER\\Environment",
                        "/t", "REG_EXPAND_SZ",
                        "/f", // no prompt for configuration
                        "/v", "Path",
                        "/d", "C:\\src\\NotInriaCaml_Std\\w64devkit\\5.4.1\\bin;C:\\opt\\w64devkit\\bin"
                    ],

                    // --- 1. ./configure --prefix C:\opt\ocaml-5.4.1 (OCaml) ---
                    // - the target destination is C:\opt\ocaml-5.4.1.
                    // - dk0 conditionally selects command only if we use a SLOT or SLOTABS, so unused _DUMMY1 is supplied
                    // - `enter-wine.sh WINEPREFIX sh.exe -l cdsrc.sh ./configure ...`
                    //
                    //  [Darwin_arm64.Windows_x86_64]
                    [
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.Release.Darwin_arm64.Windows_x86_64@5.4.1",
                        "sh.exe", "-l", "c:/src/NotInriaCaml_Std/w64devkit/5.4.1/bin/cdsrc.sh",
                        "./configure",
                        "--build=x86_64-w64-mingw32",
                        "--prefix=C:\\opt\\ocaml-5.4.1",
                        "_DUMMY1=${SLOTABS.Release.Darwin_arm64.Windows_x86_64}",
                        "--disable-ocamldoc",
                        "--disable-ocamltest",
                        "--disable-stdlib-manpages"
                    ],
                    //  [Darwin_x86_64.Windows_x86_64]
                    [
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.Release.Darwin_x86_64.Windows_x86_64@5.4.1",
                        "sh.exe", "-l", "c:/src/NotInriaCaml_Std/w64devkit/5.4.1/bin/cdsrc.sh",
                        "./configure",
                        "--build=x86_64-w64-mingw32",
                        "--prefix=C:\\opt\\ocaml-5.4.1",
                        "_DUMMY1=${SLOTABS.Release.Darwin_x86_64.Windows_x86_64}",
                        "--disable-ocamldoc",
                        "--disable-ocamltest",
                        "--disable-stdlib-manpages"
                    ],

                    // --- 2. ./config.status
                    //   avoids Wine reparse links. docs/support/INVESTIGATE-2026-02-24-ocaml-flexlink.md
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "env", "--chdir", "${CACHE}/NotInriaCaml_Std.Toolchain.W64devkit@5.4.1/src",
                        //      `enter-wine.sh WINEPREFIX sh.exe -l cdsrc.sh ./config.status`
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1",
                        "sh.exe", "-l", "c:/src/NotInriaCaml_Std/w64devkit/5.4.1/bin/cdsrc.sh",
                        "./config.status",
                        "--file", "otherlibs/dynlink/dynlink_cmo_format.mli:file_formats/cmo_format.mli",
                        "--file", "otherlibs/dynlink/dynlink_cmxs_format.mli:file_formats/cmxs_format.mli",
                        "--file", "otherlibs/dynlink/dynlink_platform_intf.mli:otherlibs/dynlink/dynlink_platform_intf.ml",
                        "--file", "otherlibs/unix/unix.ml:otherlibs/unix/unix_win32.ml"
                    ],

                    // --- 3. make in Wine (cross-native build) ---
                    [
                        //      Use `env --chdir` to change Unix directory as well as `make -C`
                        //      to change the Windows directory to the same location. That is adopted
                        //      from NotInriaCaml_Std.Toolchain.LLVM_MinGW@5.4.1 even though it may not be necessary.
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "env", "--chdir", "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/src/NotInriaCaml_Std/w64devkit/5.4.1/src",
                        //      `enter-wine.sh WINEPREFIX sh.exe -l cdsrc.sh make.exe`
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1",
                        "sh.exe", "-l", "c:/src/NotInriaCaml_Std/w64devkit/5.4.1/bin/cdsrc.sh",
                        "make.exe",
                        "AWK=C:/opt/w64devkit/bin/awk.exe",
                        //      avoids Wine reparse links. docs/support/INVESTIGATE-2026-02-24-ocaml-flexlink.md
                        "'LN=cp -pf'"
                    ],

                    // --- 4. make install ---
                    [
                        //      `enter-wine.sh WINEPREFIX sh.exe -l cdsrc.sh make.exe install`
                        "/bin/sh",
                        "$(--path=absnative get-object CommonsBase_Win32.Wine@11.2.0 -s ${SLOTNAME.Release.execution_abi} -d : -e 'bin/*' -e 'lib/wine/*/*')${/}bin${/}enter-wine.sh",
                        "--gnutls-libdir", "$(--path=absnative get-object CommonsBase_GNU.TLS@3.8.12 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--inotify-libdir", "$(--path=absnative get-object NotMatveevKondratyev_Libinotify.Kqueue@0.20240724.0 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "--krb5-libdir", "$(--path=absnative get-object NotMitEdu_Kerberos.V5@1.22.2 -s $(get-asset CommonsBase_Win32.Lookup@1.0.0 -p winerunlib-slot -m ./${SLOTNAME.Release.execution_abi}) -d :)${/}lib",
                        "${STATEABS}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1",
                        "sh.exe", "-l", "c:/src/NotInriaCaml_Std/w64devkit/5.4.1/bin/cdsrc.sh",
                        "make.exe", "'LN=cp -pf'", "install"
                    ],

                    // --- 5. move into slot ---
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mv",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/opt/ocaml-5.4.1/bin",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/opt/ocaml-5.4.1/lib",
                        "${STATE}/wineprefixes/NotInriaCaml_Std.Toolchain.W64devkit.${SLOTNAME.request}@5.4.1/drive_c/opt/ocaml-5.4.1/share",
                        "${SLOT.request}"
                    ]
                ]
            },
            "outputs": {
                "assets": [
                    {
                        "slots": [
                            "Release.Darwin_arm64.Windows_x86_64",
                            "Release.Darwin_x86_64.Windows_x86_64"
                        ],
                        "paths": [
                            "bin/flexlink.byte.exe",
                            "bin/flexlink.exe",
                            "bin/flexlink.opt.exe",
                            "bin/ocaml.exe",
                            "bin/ocamlc.byte.exe",
                            "bin/ocamlc.exe",
                            "bin/ocamlc.opt.exe",
                            "bin/ocamlcmt.exe",
                            "bin/ocamlcp.exe",
                            "bin/ocamldebug.exe",
                            "bin/ocamldep.byte.exe",
                            "bin/ocamldep.exe",
                            "bin/ocamldep.opt.exe",
                            "bin/ocamllex.byte.exe",
                            "bin/ocamllex.exe",
                            "bin/ocamllex.opt.exe",
                            "bin/ocamlmklib.exe",
                            "bin/ocamlmktop.exe",
                            "bin/ocamlobjinfo.byte.exe",
                            "bin/ocamlobjinfo.exe",
