// w64devkit is a Dockerfile that builds from source a small, portable development suite for creating C and C++ applications on and for x86 and x64 Windows.
// === ABI ===
// Release.Windows_x86_64
// Release.Windows_x86
//
// Test: ./dk0 --trial -v -I etc/dk/v --trust-local-package CommonsBase_GNU get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.Windows_x86_64 -d target/w64devkit-x64
// Test: ./dk0 --trial -v -I etc/dk/v --trust-local-package CommonsBase_GNU get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.Windows_x86 -d target/w64devkit-x86
{
  "$schema": "https://github.com/diskuv/dk/raw/refs/heads/V2_5/etc/jsonschema/dk-values.json",
  "schema_version": {
    "major": 1,
    "minor": 0
  },
  "forms": [
    {
      "id": "CommonsBase_GNU.Toolchain.W64dev@2.5.0",
      "precommands": {
        "sequential": true,
        "private": [
          // get 7zz.exe
          "get-object CommonsBase_Std.S7z@25.1.0 -s Release.execution_abi -m ./7zz.exe -f 7zz.exe -e 7zz.exe"
        ]
      },
      "function": {
        "commands": [
          // Release.Windows_x86 only: extract w64devkit-x86.7z.exe into w64devkit/
          [
            "./7zz.exe",
            "x",
            // -w is work directory. We want the side-effect that this command only runs for Release.Windows_x86
            "-w${SLOT.Release.Windows_x86}",
            "$(get-asset CommonsBase_GNU.Toolchain.W64devkit.Bundle@2.5.0 -p w64devkit-x86-2.5.0.7z.exe -f w64devkit-x86.7z.exe)"
          ],
          // Release.Windows_x86_64 only: extract w64devkit-x64.7z.exe into w64devkit/
          [
            "./7zz.exe",
            "x",
            // -w is work directory. We want the side-effect that this command only runs for Release.Windows_x86_64
            "-w${SLOT.Release.Windows_x86_64}",
            "$(get-asset CommonsBase_GNU.Toolchain.W64devkit.Bundle@2.5.0 -p w64devkit-x64-2.5.0.7z.exe -f w64devkit-x64.7z.exe)"
          ],
          // Release.Windows_*: move contents of w64devkit/ into slot
          [
            "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
            "mv",
            "w64devkit/bin", "w64devkit/COPYING.MinGW-w64-runtime.txt", "w64devkit/Dockerfile",
            "w64devkit/include", "w64devkit/lib", "w64devkit/libexec",
            "w64devkit/README.md", "w64devkit/share", "w64devkit/src",
            "w64devkit/VERSION.txt", "w64devkit/w64devkit.exe", "w64devkit/w64devkit.ini",
            "${SLOT.request}"
          ]
        ]
      },
