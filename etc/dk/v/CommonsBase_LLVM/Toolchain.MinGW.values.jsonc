      "id": "CommonsBase_LLVM.Toolchain.MinGW@21.1.8+rev-20251216",
      "precommands": {
        "sequential": true,
        "private": [
          // MACOS and LINUX
          // convert the macOS .tar.xz to .zip (we could use F_Untar but that requires paths[]= set)
          "post-object CommonsBase_Std.Extract.F_TarToZip@0.1.0 -f ${SLOT.Release.Darwin_arm64}/ignored.zip  modver=CommonsBase_LLVM.Toolchain.MinGW.Zip.MacUniversal@21.1.8+rev-20251216 tarfile=$(get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-macos-universal.tar.xz -f llvm-mingw.tar.xz)",
          "post-object CommonsBase_Std.Extract.F_TarToZip@0.1.0 -f ${SLOT.Release.Darwin_x86_64}/ignored.zip modver=CommonsBase_LLVM.Toolchain.MinGW.Zip.MacUniversal@21.1.8+rev-20251216 tarfile=$(get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-macos-universal.tar.xz -f llvm-mingw.tar.xz)",
          "post-object CommonsBase_Std.Extract.F_TarToZip@0.1.0 -f ${SLOT.Release.Linux_x86_64}/ignored.zip modver=CommonsBase_LLVM.Toolchain.MinGW.Zip.UbuntuX64@21.1.8+rev-20251216 tarfile=$(get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-ubuntu-22.04-x86_64.tar.xz -f llvm-mingw.tar.xz)",
          "post-object CommonsBase_Std.Extract.F_TarToZip@0.1.0 -f ${SLOT.Release.Linux_arm64}/ignored.zip modver=CommonsBase_LLVM.Toolchain.MinGW.Zip.UbuntuArm64@21.1.8+rev-20251216 tarfile=$(get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-ubuntu-22.04-aarch64.tar.xz -f llvm-mingw.tar.xz)",
          // extract zip to output folder, stripping toplevel llvm-mingw-20251216-ucrt-macos-universal/ folder
          "install-object CommonsBase_LLVM.Toolchain.MinGW.Zip.MacUniversal@21.1.8+rev-20251216 -s Release.Agnostic -m ./output.zip -n 1 -d ${SLOT.Release.Darwin_arm64}",
          "install-object CommonsBase_LLVM.Toolchain.MinGW.Zip.MacUniversal@21.1.8+rev-20251216 -s Release.Agnostic -m ./output.zip -n 1 -d ${SLOT.Release.Darwin_x86_64}",
          "install-object CommonsBase_LLVM.Toolchain.MinGW.Zip.UbuntuX64@21.1.8+rev-20251216 -s Release.Agnostic -m ./output.zip -n 1 -d ${SLOT.Release.Linux_x86_64}",
          "install-object CommonsBase_LLVM.Toolchain.MinGW.Zip.UbuntuArm64@21.1.8+rev-20251216 -s Release.Agnostic -m ./output.zip -n 1 -d ${SLOT.Release.Linux_arm64}",
          // WINDOWS
          // extract zip to output folder, stripping toplevel llvm-mingw-20251216-ucrt-x86_64/ (etc.) folder
          "get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-x86_64.zip -n 1 -d ${SLOT.Release.Windows_x86_64}",
          "get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-i686.zip -n 1 -d ${SLOT.Release.Windows_x86}",
          "get-asset CommonsBase_LLVM.Toolchain.MinGW.Bundle@21.1.8+rev-20251216 -p llvm-mingw-20251216-ucrt-aarch64.zip -n 1 -d ${SLOT.Release.Windows_arm64}"
        ]
      },
      "function": {
        "args": [
          // remove the ignored.zip file from macOS precommands
          [
            "$(get-object CommonsBase_Std.Coreutils@0.2.2 -s Release.execution_abi -m ./coreutils.exe -e coreutils.exe -f coreutils.exe)",
            "rm",
            "-f",
            "${SLOT.request}/ignored.zip"
          ]
        ]
